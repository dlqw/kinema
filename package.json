{
  "name": "animaker",
  "version": "0.1.0",
  "description": "High-performance 2D animation rendering framework + Electron workstation",
  "type": "module",
  "main": "./electron/out/main/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run --config vitest.config.ts --dir tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage",
    "ci:test": "./scripts/ci/test.sh",
    "ci:build": "./scripts/ci/build.sh",
    "clean": "rm -rf dist coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:api": "typedoc --options docs/typedoc.config.json",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build && electron-builder",
    "electron:preview": "electron-vite preview"
  },
  "keywords": [
    "animation",
    "rendering",
    "webgl",
    "webgpu",
    "canvas",
    "2d",
    "3d",
    "framework",
    "graphics",
    "typescript"
  ],
  "author": "AniMaker Team",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.1",
    "playwright": "^1.45.0",
    "prettier": "^3.2.0",
    "typedoc": "^0.25.7",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.1",
    "vitepress": "^1.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "canvas": "^3.2.1",
    "gl-matrix": "^3.4.3",
    "i18next": "^25.8.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "zustand": "^5.0.12"
  }
}
